includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:

    paths:
        - app
        - bootstrap
        - config
        - database
        - routes

    # Level 10 is the highest level
    level: 7

    ignoreErrors:

    excludePaths:

    editorUrl: 'vscode://file/%%file%%:%%line%%'
